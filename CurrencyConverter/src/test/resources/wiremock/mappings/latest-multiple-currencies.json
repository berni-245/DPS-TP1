{
  "request": {
    "method": "GET",
    "urlPath": "/v1/latest",
    "queryParameters": {
      "base_currency": {
        "equalTo": "EUR"
      },
      "currencies": {
        "equalTo": "USD,CAD"
      }
    }
  },
  "response": {
    "status": 200,
    "bodyFileName": "latest-eur-usd-cad-response.json",
    "headers": {
      "Content-Type": "application/json"
    }
  }
}
