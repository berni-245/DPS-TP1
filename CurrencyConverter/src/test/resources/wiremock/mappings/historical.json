{
  "request": {
    "method": "GET",
    "urlPath": "/v1/historical",
    "queryParameters": {
      "base_currency": {
        "equalTo": "EUR"
      },
      "date": {
        "equalTo": "2022-01-01"
      },
      "currencies": {
        "equalTo": "USD"
      }
    }
  },
  "response": {
    "status": 200,
    "bodyFileName": "historical-eur-usd-response.json",
    "headers": {
      "Content-Type": "application/json"
    }
  }
}
